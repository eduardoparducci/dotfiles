;; Kill default buffers
(defun startup-layout ()
  "Kill all unused default Buffers on init."
  (interactive)
  (delete-other-windows)
  (setq-default message-log-max nil)
  (kill-buffer "*Messages*")
  (split-window-vertically)
  (other-window 1)
  (term "/bin/bash")
  (defvar linum-mode)
  (setq-local linum-mode nil))
(setq inhibit-startup-screen t)
(startup-layout)

;; Disable menu and scrolling bars
(tool-bar-mode -1)
(menu-bar-mode -1)
(scroll-bar-mode -1)
(fringe-mode -1)

;; Enable and config Tabbar
(require 'cl)
(require 'tabbar)
;; Ignore this buffers
(defvar *tabbar-ignore-buffers*)
(setq *tabbar-ignore-buffers* '("work.org" "school.org" "personal.org"))
;; remove buffers from list above and with name starting from '*'
(tabbar-mode 1)
(tabbar-install-faces)
(when (require 'tabbar nil t)
  (setq tabbar-buffer-groups-function
        (lambda () (list "All Buffers")))
  (setq tabbar-buffer-list-function
        (lambda ()
          (remove-if
           (lambda(buffer)
             (or (find (aref (buffer-name buffer) 0) " *")
             (loop for name in *tabbar-ignore-buffers*
                   thereis (string-equal (buffer-name buffer) name))))
           (buffer-list))))
  (tabbar-mode))

